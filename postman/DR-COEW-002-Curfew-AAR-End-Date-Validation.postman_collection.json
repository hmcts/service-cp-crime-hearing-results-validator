{
  "info": {
    "name": "DR-COEW-002 — Curfew & AAR End-Date Validation",
    "description": "Postman collection covering all 12 scenarios for DR-COEW-002.\n\nRule: Validates that the end date recorded for a Curfew requirement (CUR, CURE, YRC2, YRC1) equals startDate + period − 1 day, and that the 'Until' date for an AAR requirement equals hearingDate + abstinenceDays − 1 day.\n\nBase URL variable: {{baseUrl}} — defaults to http://localhost:4550",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4550",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Curfew (CUR / CURE / YRC2 / YRC1)",
      "item": [
        {
          "name": "S1 — CUR day mismatch → ERROR (expects 30/07/2026)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "CJSCPPUID",    "value": "postman-user" },
              { "key": "CPP-ACTION",   "value": "validation-service.validate" }
            ],
            "url": { "raw": "{{baseUrl}}/api/validation/validate", "host": ["{{baseUrl}}"], "path": ["api","validation","validate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hearingId\": \"h-s1\",\n  \"hearingDay\": \"2026-01-01\",\n  \"courtType\": \"MAGISTRATES\",\n  \"resultLines\": [\n    {\n      \"id\": \"rl-order\",\n      \"shortCode\": \"COEW\",\n      \"category\": \"F\",\n      \"label\": \"Community order\",\n      \"defendantId\": \"d1\",\n      \"offenceId\": \"off1\",\n      \"prompts\": [{\"promptRef\": \"endDate\", \"promptValue\": \"2026-12-31\"}]\n    },\n    {\n      \"id\": \"rl-cur\",\n      \"shortCode\": \"CUR\",\n      \"category\": \"I\",\n      \"label\": \"Curfew\",\n      \"defendantId\": \"d1\",\n      \"offenceId\": \"off1\",\n      \"prompts\": [\n        {\"promptRef\": \"startDate\", \"promptValue\": \"2026-06-01\"},\n        {\n          \"promptRef\": \"curfewPeriod\",\n          \"type\": \"DURATION\",\n          \"childPrompts\": [{\"promptRef\": \"Days\", \"promptValue\": \"60\", \"type\": \"INT\"}]\n        },\n        {\"promptRef\": \"endDate\", \"promptValue\": \"2026-07-31\"}\n      ]\n    }\n  ],\n  \"defendants\": [{\"id\": \"d1\", \"firstName\": \"John\", \"lastName\": \"Smith\"}],\n  \"offences\": [{\"id\": \"off1\", \"offenceCode\": \"TH68001\", \"offenceTitle\": \"Theft\", \"orderIndex\": 1}]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "start=2026-06-01, 60 Days → expected=2026-07-30, actual=2026-07-31.\nExpect: DR-COEW-002 ERROR, message contains '30/07/2026', affectedDefendants[0].defendantId='d1'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const issues = body.errors.validationIssues.filter(i => i.ruleId === 'DR-COEW-002');",
                  "pm.test(\"DR-COEW-002 error emitted\", () => pm.expect(issues).to.have.lengthOf(1));",
                  "pm.test(\"severity is ERROR\", () => pm.expect(issues[0].severity).to.eql('ERROR'));",
                  "pm.test(\"message contains expected date\", () => pm.expect(issues[0].affectedOffences[0].message).to.include('30/07/2026'));",
                  "pm.test(\"affectedDefendants contains d1\", () => pm.expect(issues[0].affectedDefendants[0].defendantId).to.eql('d1'));",
                  "pm.test(\"affectedOffences contains off1\", () => pm.expect(issues[0].affectedOffences[0].offenceId).to.eql('off1'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
